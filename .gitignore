# =========================
# Unity .gitignore (Full)
# =========================

# ========== Unity Generated ==========
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset Store Tools (optional)
# [Aa]ssets/AssetStoreTools*

# JetBrains Rider
[Aa]ssets/Plugins/Editor/JetBrains*

# Addressables (generated content)
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# StreamingAssets (auto-generated)
[Aa]ssets/[Ss]treamingAssets/aa.meta
[Aa]ssets/[Ss]treamingAssets/aa/*

# ========== Visual Studio / IDE ==========
.vs/
.gradle/
.consulo/
ExportedObj/

# Auto-generated project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity meta crash files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Logs
*.log

# Crash reports
sysinfo.txt

# ========== Builds ==========
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# iOS / Xcode (important for your error!)
*.xcworkspace
*.xcodeproj
*.xcuserdata
*.xcuserstate

# ========== OS Files ==========
.DS_Store
Thumbs.db

# ========== Git ==========
.gitignore
.gitattributes
